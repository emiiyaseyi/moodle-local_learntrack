<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/learnpath/db" VERSION="20250201" COMMENT="LearnTrack v2.0.0 — Michael Adeniran">
  <TABLES>

    <!-- Learning path group definitions -->
    <TABLE NAME="local_learnpath_groups" COMMENT="Learning path groups">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10"  NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="name"         TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description"  TYPE="text"              NOTNULL="false"/>
        <FIELD NAME="grouptype"    TYPE="char" LENGTH="20"  NOTNULL="true"  DEFAULT="manual" COMMENT="manual|category|cohort"/>
        <FIELD NAME="categoryid"   TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="cohortid"     TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="deadline"     TYPE="int"  LENGTH="10"  NOTNULL="false" COMMENT="Unix timestamp deadline"/>
        <FIELD NAME="adminnotes"   TYPE="text"              NOTNULL="false"/>
        <FIELD NAME="createdby"    TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10"  NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Courses assigned to a learning path -->
    <TABLE NAME="local_learnpath_group_courses" COMMENT="Courses in a learning path">
      <FIELDS>
        <FIELD NAME="id"        TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"   TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseid"  TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group"  TYPE="foreign" FIELDS="groupid"  REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_course" TYPE="foreign" FIELDS="courseid" REFTABLE="course"                 REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Manager assignments per path (admin assigns managers to paths) -->
    <TABLE NAME="local_learnpath_managers" COMMENT="Managers assigned to learning paths">
      <FIELDS>
        <FIELD NAME="id"      TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"  TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="scope"   TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="cohort" COMMENT="cohort|courses|all"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_user"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Scheduled email reports -->
    <TABLE NAME="local_learnpath_schedules" COMMENT="Scheduled email reports">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="recipients"  TYPE="text"             NOTNULL="true"/>
        <FIELD NAME="frequency"   TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="weekly"/>
        <FIELD NAME="format"      TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="xlsx"/>
        <FIELD NAME="viewmode"    TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="summary"/>
        <FIELD NAME="nextrun"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="lastrun"     TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="createdby"   TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="enabled"     TYPE="int"  LENGTH="1"  NOTNULL="true" DEFAULT="1"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Reminder / nudge rules -->
    <TABLE NAME="local_learnpath_reminders" COMMENT="Reminder rules for learners">
      <FIELDS>
        <FIELD NAME="id"            TYPE="int"  LENGTH="10"  NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"       TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="name"          TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="target"        TYPE="char" LENGTH="20"  NOTNULL="true" DEFAULT="incomplete"/>
        <FIELD NAME="channel_email" TYPE="int"  LENGTH="1"   NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="channel_inapp" TYPE="int"  LENGTH="1"   NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="channel_sms"   TYPE="int"  LENGTH="1"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="subject"       TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="message"       TYPE="text"              NOTNULL="false"/>
        <FIELD NAME="frequency"     TYPE="char" LENGTH="20"  NOTNULL="true" DEFAULT="once"/>
        <FIELD NAME="nextrun"       TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="lastrun"       TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="enabled"       TYPE="int"  LENGTH="1"   NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="createdby"     TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="timecreated"   TYPE="int"  LENGTH="10"  NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Log of sent reminders -->
    <TABLE NAME="local_learnpath_reminder_log" COMMENT="Sent reminder log">
      <FIELDS>
        <FIELD NAME="id"         TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="reminderid" TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="channel"    TYPE="char" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timesent"   TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="status"     TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="sent"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"     TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_reminder" TYPE="foreign" FIELDS="reminderid" REFTABLE="local_learnpath_reminders" REFFIELDS="id"/>
        <KEY NAME="fk_user"     TYPE="foreign" FIELDS="userid"     REFTABLE="user"                      REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Certificate issuance records -->
    <TABLE NAME="local_learnpath_certs" COMMENT="Certificate issuance records">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"      TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="issuedby"    TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="issuedate"   TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="certnumber"  TYPE="char" LENGTH="64" NOTNULL="false"/>
        <FIELD NAME="notes"       TYPE="text"             NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_user"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Admin notes per learner per path -->
    <TABLE NAME="local_learnpath_notes" COMMENT="Admin notes per learner">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"      TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"       TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="authorid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="note"         TYPE="text"             NOTNULL="true"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_user"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <!-- Progress cache for performance -->
    <TABLE NAME="local_learnpath_progress_cache" COMMENT="Cached progress per learner per group">
      <FIELDS>
        <FIELD NAME="id"                TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"           TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"            TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="completed_courses" TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="total_courses"     TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="overall_progress"  TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="firstaccess"       TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="lastaccess"        TYPE="int"  LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timeupdated"       TYPE="int"  LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_user"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="groupid_userid" UNIQUE="true" FIELDS="groupid, userid"/>
      </INDEXES>
    </TABLE>

    <!-- Individual user assignments to learning paths -->
    <TABLE NAME="local_learnpath_user_assign" COMMENT="Individual user assignments to learning paths">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid"      TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="assignedby"  TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_group" TYPE="foreign" FIELDS="groupid" REFTABLE="local_learnpath_groups" REFFIELDS="id"/>
        <KEY NAME="fk_user"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="groupid_userid" UNIQUE="true" FIELDS="groupid, userid"/>
      </INDEXES>
    </TABLE>


    <!-- Leaderboard criteria defined by admin -->
    <TABLE NAME="local_learnpath_criteria" COMMENT="Leaderboard scoring criteria">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name"        TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="points"      TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="10"/>
        <FIELD NAME="event_type"  TYPE="char" LENGTH="50"  NOTNULL="true"/>
        <FIELD NAME="enabled"     TYPE="int"  LENGTH="1"   NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="sortorder"   TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10"  NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
    </TABLE>

    <!-- Leaderboard points earned by each learner -->
    <TABLE NAME="local_learnpath_points" COMMENT="Points earned by learners">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid"      TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="criteriaid"  TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="points"      TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseid"    TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="groupid"     TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
      <INDEXES><INDEX NAME="idx_user" UNIQUE="false" FIELDS="userid"/></INDEXES>
    </TABLE>

    <!-- Badges defined by admin -->
    <TABLE NAME="local_learnpath_badges" COMMENT="Leaderboard badges">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10"  NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name"         TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description"  TYPE="text" NOTNULL="false"/>
        <FIELD NAME="icon"         TYPE="char" LENGTH="10"  NOTNULL="true" DEFAULT="🏅"/>
        <FIELD NAME="points_req"   TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="sortorder"    TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10"  NOTNULL="true"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
    </TABLE>

    <!-- Badges awarded to learners -->
    <TABLE NAME="local_learnpath_user_badges" COMMENT="Badges awarded to learners">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid"      TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="badgeid"     TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="seen"        TYPE="int" LENGTH="1"  NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS><KEY NAME="primary" TYPE="primary" FIELDS="id"/></KEYS>
      <INDEXES><INDEX NAME="idx_user_badge" UNIQUE="false" FIELDS="userid,badgeid"/></INDEXES>
    </TABLE>

      <TABLE NAME="local_learnpath_email_log" COMMENT="Log of sent report emails">
      <FIELDS>
        <FIELD NAME="id"         TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"    TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="senderid"   TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="recipients" TYPE="text"             NOTNULL="true"/>
        <FIELD NAME="format"     TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="xlsx"/>
        <FIELD NAME="viewmode"   TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="summary"/>
        <FIELD NAME="recordcount" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timesent"   TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="groupid" UNIQUE="false" FIELDS="groupid"/>
        <INDEX NAME="timesent" UNIQUE="false" FIELDS="timesent"/>
      </INDEXES>
    </TABLE>
  
    <!-- Manager invites (email-based) -->
    <TABLE NAME="local_learnpath_mgr_invites" COMMENT="Manager invite links">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="email"       TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="token"       TYPE="char" LENGTH="64"  NOTNULL="true"/>
        <FIELD NAME="invitedby"   TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="status"      TYPE="char" LENGTH="20"  NOTNULL="true" DEFAULT="pending"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="timeaccepted"TYPE="int"  LENGTH="10"  NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>

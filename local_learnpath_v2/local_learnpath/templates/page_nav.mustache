{{!
    @template local_learnpath/page_nav

    Renders the breadcrumb/back-navigation link at the top of plugin pages.

    Context variables:
    - back_url   string  URL to navigate back to
    - back_label string  Link text e.g. "← Dashboard"
    - home_url   string  URL to the welcome page (optional)

    @copyright 2025 Michael Adeniran
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<nav class="lt-page-nav" aria-label="{{#str}}back_to_dashboard, local_learnpath{{/str}}">
    {{#home_url}}
    <a href="{{home_url}}" class="lt-page-nav__link">&#x1F3E0; {{#str}}overview, local_learnpath{{/str}}</a>
    <span class="lt-page-nav__sep" aria-hidden="true">·</span>
    {{/home_url}}
    <a href="{{back_url}}" class="lt-page-nav__link">{{back_label}}</a>
</nav>

{{!
    @template local_learnpath/schedule_list_item

    Renders a single row in the scheduled-reports list.

    Context variables:
    - freq_icon      string  Emoji/icon for the frequency badge
    - freq_bg        string  CSS background colour for the icon cell
    - freq_label     string  Human-readable frequency e.g. "Weekly"
    - format_label   string  Uppercase format e.g. "XLSX"
    - is_active      bool    Schedule is enabled
    - recipients     string  Comma-separated recipient addresses
    - next_run       string  Formatted next-run date
    - last_run       string  Formatted last-run date (empty if never)
    - has_last_run   bool    True when last_run is set
    - toggle_url     string  URL to pause/resume
    - edit_url       string  URL to edit the schedule
    - delete_url     string  URL to delete (includes sesskey)
    - toggle_label   string  "Pause" or "Resume"

    @copyright 2025 Michael Adeniran
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="lt-schedule-item">
    <div class="lt-schedule-item__icon" style="background:{{freq_bg}}">{{freq_icon}}</div>
    <div class="lt-schedule-item__body">
        <p class="lt-schedule-item__title">
            {{freq_label}} &middot; {{format_label}}
            &nbsp;
            {{#is_active}}
            <span class="lt-badge lt-badge--success">{{#str}}schedule_enabled, local_learnpath{{/str}}</span>
            {{/is_active}}
            {{^is_active}}
            <span class="lt-badge lt-badge--muted">Paused</span>
            {{/is_active}}
        </p>
        <p class="lt-schedule-item__meta">
            &#x1F4E7; {{recipients}}
            &nbsp;&middot;&nbsp;
            Next: {{next_run}}
            {{#has_last_run}}&nbsp;&middot;&nbsp; Last: {{last_run}}{{/has_last_run}}
        </p>
    </div>
    <div class="lt-schedule-item__actions">
        <a href="{{toggle_url}}" class="lt-action-btn lt-btn-view">{{toggle_label}}</a>
        <a href="{{edit_url}}" class="lt-action-btn lt-btn-edit">&#x270F;&#xFE0F; {{#str}}edit_schedule, local_learnpath{{/str}}</a>
        <a href="{{delete_url}}"
           class="lt-action-btn lt-btn-del"
           data-confirm="{{#str}}confirm_delete_group, local_learnpath{{/str}}">&#x1F5D1;</a>
    </div>
</div>

{{!
    @template local_learnpath/dynamic_styles

    Injects CSS custom properties for brand colour, font size, and
    accessibility overrides. Rendered from PHP via $OUTPUT->render_from_template().

    Context variables:
    - brand_color   string  Hex colour e.g. #1e3a5f
    - font_size     int     Base font size in px (default 13)
    - high_contrast bool    Enable high-contrast borders
    - reduce_motion bool    Disable transitions/animations

    @copyright 2025 Michael Adeniran
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<style>
:root {
    --lt-primary:         {{brand_color}};
    --lt-accent:          {{brand_color}};
    --lt-primary-dark:    {{brand_color}}cc;
    --lt-primary-pale:    {{brand_color}}15;
    --lt-data-font-size:  {{font_size}}px;
}
{{#high_contrast}}
.lt-data-table tbody tr { border-bottom: 2px solid #374151 !important; }
.lt-badge { font-weight: 800 !important; border: 2px solid currentColor !important; }
.lt-card { border-width: 2px !important; }
{{/high_contrast}}
{{#reduce_motion}}
*, *::before, *::after { transition: none !important; animation: none !important; }
{{/reduce_motion}}
{{#large_text}}
body { font-size: 16px !important; }
.lt-data-table td, .lt-data-table th { font-size: .95rem !important; }
{{/large_text}}
</style>

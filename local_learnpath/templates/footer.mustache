{{!
    @template local_learnpath/footer

    Renders the plugin footer bar shown at the bottom of every plugin page.

    Context variables:
    - linkedin_url  string  LinkedIn profile URL
    - version       string  Plugin version string e.g. "v2.0.0"
    - author        string  Copyright holder name

    @copyright 2025 Michael Adeniran
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="lt-footer">
    <span>&#x00A9; {{author}}</span>
    <span class="lt-sep" aria-hidden="true">·</span>
    <a href="{{linkedin_url}}" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <span class="lt-sep" aria-hidden="true">·</span>
    <span>LearnTrack {{version}}</span>
</div>
